# AutoMech Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM Configuration
# ============================================================================

# Groq API Key (REQUIRED)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LLM Mode Selection
# - Set to "true" for production/hosting (always use Groq API)
# - Set to "false" for development (try local Ollama first, fallback to Groq)
# Recommended: true for hosting, false for local development
PREFER_CLOUD_LLM=false

# ============================================================================
# Database Configuration
# ============================================================================

# Database URL
# Development: Use SQLite (default if not set)
# Production: Use PostgreSQL (recommended)
# 
# SQLite (development):
# DATABASE_URL=sqlite:///./automech.db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://username:password@host:5432/automech
#
# Leave empty to use SQLite by default
DATABASE_URL=

# ============================================================================
# Security Configuration
# ============================================================================

# JWT Secret Key (REQUIRED for production)
# Generate a secure random string (32+ characters)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# ⚠️ IMPORTANT: Change this in production!
JWT_SECRET_KEY=automech-super-secret-key-change-this-in-production-min-32-characters-long

# ============================================================================
# Optional: Google OAuth (for future authentication)
# ============================================================================

# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================================================
# Optional: Advanced Configuration
# ============================================================================

# API Port (default: 8000)
# PORT=8000

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# Log Level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
